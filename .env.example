# MR NOTHING Backend Environment Variables

# API server
PORT=8400
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mrnothing

# Memory (Qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=mrnothing_memory

# Voice (Whisper)
WHISPER_MODEL=base

# Optional Redis
REDIS_URL=redis://localhost:6379

# JWT (for API auth)
JWT_SECRET=your-secret-min-32-chars
